	journal = {Journal of Agricultural and Food Chemistry},
	publisher = {American Chemical Society},
	author = {Missinou, Anani Amegan and Carvalho, Julie Ferreira de and Marnet, Nathalie and Delhaye, Thomas and Hamzaoui, Oumayma and Sayed, David Abdel and Guitton, Yann and Lebreton, Lionel and Langrume, Christophe and Laperche, Anne and Delourme, Régine and Manzanares-Dauleux, Maria J. and Bouchereau, Alain and Gravot, Antoine},
