	year = {2002},
	keywords = {Agile Process, Data Conceptual Model, Extended Database Technology, Methodological Framework, Navigation Model},
	pages = {227--238},
	file = {Full Text PDF:/home/ofilangi/Zotero/storage/PGP73Y8C/Marcos et al. - 2002 - MIDASBD A Methodological Framework for Web Datab.pdf:application/pdf},
}

@inproceedings{atzeni_design_1998,
