	pages = {giz044},
	file = {Full Text PDF:/home/ofilangi/Zotero/storage/ZIWSDNTL/Lampa et al. - 2019 - SciPipe A workflow library for agile development .pdf:application/pdf;Snapshot:/home/ofilangi/Zotero/storage/79G38KPF/5480570.html:text/html},
