	keywords = {Software, User-Computer Interface, Databases, Factual, Information Storage and Retrieval, Vocabulary, Controlled, Database Management Systems, Natural Language Processing, Programming Languages},
	pages = {97},
	file = {Texte intégral:/home/ofilangi/Zotero/storage/73C3Q54G/Côté et al. - 2006 - The Ontology Lookup Service, a lightweight cross-p.pdf:application/pdf},
