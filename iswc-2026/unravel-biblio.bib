	keywords = {Data processing, Molecular biology},
	pages = {411--421},
	file = {Full Text PDF:/home/ofilangi/Zotero/storage/7CA8YTGH/Hoffmann et al. - 2022 - High-confidence structural annotation of metabolit.pdf:application/pdf;Snapshot:/home/ofilangi/Zotero/storage/GTHWEIVG/s41587-021-01045-9.html:text/html},
