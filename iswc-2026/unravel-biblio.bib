	year = {2020},
	keywords = {SPARQL, Indexing, RDF, alternative SPARQL query, conjunctive SPARQL query, Data models, Dictionaries, graph-based index, Memory, optional SPARQL query, Query processing, Reactive power, Resource description framework},
	pages = {153--158},
	file = {IEEE Xplore Abstract Record:/home/ofilangi/Zotero/storage/MXEB3RSY/9261805.html:text/html},
}

